VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=
VITE_GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Google Sheets API sync (soluzione robusta per aggiornare la stessa riga)
# Prendi l'ID dallo spreadsheet URL:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# Nome del tab/foglio da aggiornare. Esempio: Foglio1
GOOGLE_SHEETS_TAB=Foglio1

# Opzione A: path locale al JSON del service account
# GOOGLE_APPLICATION_CREDENTIALS=/Users/tuo-utente/Desktop/google-service-account.json

# Opzione B: JSON completo inline (utile su Vercel)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
