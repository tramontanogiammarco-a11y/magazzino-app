{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/analyze.js": {
      "maxDuration": 120
    },
    "api/sheets-forward.js": {
      "maxDuration": 30
    },
    "api/image-proxy.js": {
      "maxDuration": 30
    },
    "api/convert-image.js": {
      "maxDuration": 60
    }
  }
}
