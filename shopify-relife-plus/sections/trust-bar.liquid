<section class="section">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <div class="section-heading">
        <p class="section-eyebrow">Fiducia</p>
        <h2>{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="trust-grid">
      {% for block in section.blocks %}
        <article class="trust-card" {{ block.shopify_attributes }}>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust bar",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titolo", "default": "Perché sceglierci" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Elemento",
      "settings": [
        { "type": "text", "id": "title", "label": "Titolo", "default": "12 mesi di garanzia" },
        { "type": "text", "id": "text", "label": "Testo", "default": "Lavorazione coperta con condizioni chiare e supporto post intervento." }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [{ "name": "Trust bar" }]
}
{% endschema %}
