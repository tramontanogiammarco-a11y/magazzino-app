<section class="section" {% if section.settings.anchor_id != blank %}id="{{ section.settings.anchor_id }}"{% endif %}>
  <div class="page-width">
    <div class="section-heading">
      <p class="section-eyebrow">Processo</p>
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.text != blank %}
        <div class="section-copy rte">{{ section.settings.text }}</div>
      {% endif %}
    </div>

    <div class="steps-grid">
      {% for block in section.blocks %}
        <article class="step-card" {{ block.shopify_attributes }}>
          <div class="step-card__index">Step {{ forloop.index }}</div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Process steps",
  "settings": [
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "processo" },
    { "type": "text", "id": "heading", "label": "Titolo", "default": "Come funziona il processo" },
    { "type": "richtext", "id": "text", "label": "Testo", "default": "<p>Quattro fasi semplici da capire, progettate per darti una batteria più efficiente senza improvvisazioni.</p>" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Titolo", "default": "Analisi iniziale" },
        { "type": "text", "id": "text", "label": "Testo", "default": "La batteria viene sottoposta a diagnosi dedicata per identificare il reale stato del pacco e delle singole celle." }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{ "name": "Process steps" }]
}
{% endschema %}
