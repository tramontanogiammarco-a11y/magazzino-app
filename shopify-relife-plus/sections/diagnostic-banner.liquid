<section class="section">
  <div class="page-width diagnostic-banner">
    <div class="diagnostic-banner__content">
      <p class="section-eyebrow">Diagnosi</p>
      <h2>{{ section.settings.heading }}</h2>
      <div class="section-copy rte">{{ section.settings.text }}</div>
    </div>
    {% assign codes = section.settings.code_list | newline_to_br | split: '<br />' %}
    <div class="diagnostic-banner__codes">
      {% for code in codes %}
        {% assign trimmed = code | strip %}
        {% if trimmed != blank %}
          <span class="diagnostic-code">{{ trimmed }}</span>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Diagnostic banner",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titolo", "default": "Hai un errore batteria o prestazioni in calo?" },
    { "type": "richtext", "id": "text", "label": "Testo", "default": "<p>Se l'auto segnala anomalie o hai notato un peggioramento nell'utilizzo quotidiano, possiamo fare una prima valutazione tecnica e dirti rapidamente come muoverti.</p>" },
    { "type": "textarea", "id": "code_list", "label": "Codici esempio", "default": "P0A80\nP3000\nP0A7F\nP3001\nP3024" }
  ],
  "presets": [{ "name": "Diagnostic banner" }]
}
{% endschema %}
