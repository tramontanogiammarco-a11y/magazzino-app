<section class="section">
  <div class="page-width contact-layout">
    <div class="section-heading">
      <p class="section-eyebrow">Contatti</p>
      <h1>{{ section.settings.heading }}</h1>
      <div class="section-copy rte">{{ section.settings.text }}</div>
    </div>

    <div class="contact-layout__grid">
      <div class="contact-card">
        <p class="contact-card__title">Contatti rapidi</p>
        <div class="contact-card__lines">
          Tel: {{ settings.phone_number | default: '+39 329 201 1217' }}<br>
          WhatsApp: {{ settings.phone_number | default: '+39 329 201 1217' }}<br>
          Email: relifebatterys@gmail.com
        </div>
      </div>

      <div class="contact-card">
        <p class="contact-card__title">Invia una richiesta</p>
        {% form 'contact', class: 'contact-form' %}
          <div class="contact-form__grid">
            <input type="text" name="contact[name]" placeholder="Nome e cognome">
            <input type="email" name="contact[email]" placeholder="Email">
            <input type="text" name="contact[phone]" placeholder="Telefono">
            <input type="text" name="contact[modello_auto]" placeholder="Modello auto">
          </div>
          <textarea name="contact[body]" rows="6" placeholder="Descrivi il problema o il codice errore"></textarea>
          <button class="button" type="submit">Invia richiesta</button>
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact page",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titolo", "default": "Contattaci" },
    { "type": "richtext", "id": "text", "label": "Testo", "default": "<p>Raccontaci il modello dell'auto, l'errore segnalato e qualsiasi dettaglio utile. Ti ricontattiamo per una prima valutazione.</p>" }
  ]
}
{% endschema %}
