<section class="section">
  <div class="page-width faq-section">
    <div class="section-heading">
      <p class="section-eyebrow">FAQ</p>
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div class="faq-list">
      {% for block in section.blocks %}
        <details class="faq-item" {{ block.shopify_attributes }} {% if forloop.first %}open{% endif %}>
          <summary>{{ block.settings.question }}</summary>
          <div class="faq-item__content">{{ block.settings.answer }}</div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ accordion",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titolo", "default": "Domande frequenti" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Domanda", "default": "Quando conviene rigenerare la batteria?" },
        { "type": "textarea", "id": "answer", "label": "Risposta", "default": "Quando il sistema segnala errori, l'autonomia cala oppure le prestazioni non sono più stabili." }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [{ "name": "FAQ accordion" }]
}
{% endschema %}
