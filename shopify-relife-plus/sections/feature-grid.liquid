<section class="section section--alt">
  <div class="page-width">
    <div class="section-heading">
      <p class="section-eyebrow">Servizio</p>
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.text != blank %}
        <div class="section-copy rte">{{ section.settings.text }}</div>
      {% endif %}
    </div>

    <div class="feature-grid">
      {% for block in section.blocks %}
        <article class="feature-card" {{ block.shopify_attributes }}>
          <span class="feature-card__badge">{{ forloop.index | prepend: '0' }}</span>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Feature grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titolo", "default": "Un servizio più chiaro, più tecnico, più conveniente" },
    { "type": "richtext", "id": "text", "label": "Testo", "default": "<p>Abbiamo ripensato l'esperienza per chi vuole capire subito costi, tempi e vantaggi, senza testo inutile.</p>" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "title", "label": "Titolo", "default": "Risparmio concreto" },
        { "type": "text", "id": "text", "label": "Testo", "default": "Una soluzione più sostenibile della sostituzione completa, senza rinunciare all'affidabilità." }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{ "name": "Feature grid" }]
}
{% endschema %}
