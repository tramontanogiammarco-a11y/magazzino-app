<footer class="site-footer" id="contatti">
  <div class="page-width site-footer__inner">
    <div>
      <p class="section-eyebrow">Relife Battery Srls</p>
      <h2 class="footer-title">Contatti rapidi</h2>
      <p class="footer-copy">Per una valutazione veloce, contattaci direttamente oppure scrivici su WhatsApp.</p>
      <div class="footer-links">
        <a href="/pages/contact">Contatti</a>
        <a href="/pages/privacy-policy">Privacy</a>
      </div>
    </div>

    <div class="footer-actions">
      <a class="button" href="tel:{{ settings.phone_number | default: '+39 329 201 1217' }}">Chiama ora</a>
      <a class="button button--ghost" href="{{ settings.whatsapp_url | default: 'https://wa.me/393292011217' }}">WhatsApp</a>
    </div>
  </div>
</footer>

<a class="whatsapp-float" href="{{ settings.whatsapp_url | default: 'https://wa.me/393292011217' }}" aria-label="Apri WhatsApp">
  <span class="whatsapp-float__icon">✆</span>
  <span class="whatsapp-float__text">WhatsApp</span>
</a>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
