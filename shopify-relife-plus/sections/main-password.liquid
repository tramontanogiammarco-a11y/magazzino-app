<section class="section">
  <div class="page-width state-panel state-panel--password">
    <p class="section-eyebrow">Area riservata</p>
    <h1>Il sito e in preparazione.</h1>
    <p class="section-copy">
      Stiamo completando i contenuti. Se hai bisogno di una valutazione per la batteria ibrida, puoi contattarci subito.
    </p>

    {% form 'storefront_password', class: 'password-form' %}
      {%- if form.errors -%}
        <div class="password-form__error">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <label class="password-form__label" for="Password">Password</label>
      <div class="password-form__row">
        <input
          class="password-form__input"
          type="password"
          name="password"
          id="Password"
          autocomplete="current-password"
          placeholder="Inserisci la password"
        >
        <button class="button" type="submit">Entra</button>
      </div>
    {% endform %}

    <div class="state-panel__actions">
      <a class="button button--ghost" href="tel:{{ settings.phone_number | default: '+39 329 201 1217' }}">Chiama ora</a>
      <a class="button button--ghost" href="{{ settings.whatsapp_url | default: 'https://wa.me/393292011217' }}">WhatsApp</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Password",
  "settings": []
}
{% endschema %}
